{
  "name": "news-research-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "deploy": "npm run build && npm run build:worker && OPEN_NEXT_DEPLOY=true wrangler deploy --containers-rollout immediate",
    "deploy:worker-only": "npm run build && npm run build:worker && OPEN_NEXT_DEPLOY=true wrangler deploy --containers-rollout=none",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test -c tests/e2e/playwright.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:do": "drizzle-kit generate --config drizzle.config.do.ts",
    "db:migrate": "wrangler d1 migrations apply news-research-agent-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply news-research-agent-db --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.78",
    "@ai-sdk/openai": "3.0.64",
    "@ai-sdk/react": "3.0.190",
    "@cloudflare/sandbox": "0.10.1",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-hover-card": "^1.1.5",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.188",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.469.0",
    "motion": "^12.39.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "papaparse": "5.5.3",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.0.1",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.0",
    "@cloudflare/workers-types": "4.20260521.1",
    "@eslint/eslintrc": "^3.2.0",
    "@opennextjs/cloudflare": "1.19.11",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.1",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.1.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.0",
    "wrangler": "4.93.0"
  }
}
